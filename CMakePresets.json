{
    "version": 8,
    "configurePresets": [
        {
            "name": "Debug Clang x86_64-pc-linux-gnu",
            "displayName": "Debug Clang x86_64-pc-linux-gnu",
            "description": "Using compilers: C = /usr/bin/clang",
            "binaryDir": "${sourceDir}/build/debug",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/debug",
                "CMAKE_C_COMPILER": "/usr/bin/clang",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        }
    ]
}
